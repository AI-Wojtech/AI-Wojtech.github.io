---
import { Mail } from "lucide-astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout
  title="Contact"
  description="Have a platform to improve, an idea to validate, or a technical direction to clarify? Feel free to email me anytime."
  mainClass="contact-page-layout"
>
  <section class="contact-hero" aria-labelledby="contact-title">
    <div class="contact-hero-copy">
      <h1 id="contact-title" class="contact-hero-title">Let's connect.</h1>
      <p class="contact-hero-lead">
        Have a platform to improve, an idea to validate, or a technical direction to clarify?
      </p>
      <p class="contact-hero-sublead">Feel free to email me anytime.</p>
    </div>

    <div class="contact-card">
      <div class="contact-card-icon" aria-hidden="true">
        <Mail size={34} />
      </div>

      <button
        type="button"
        class="contact-email-copy"
        data-contact-copy="wojseweryn@gmail.com"
        aria-label="Copy wojseweryn@gmail.com"
      >
        wojseweryn@gmail.com
      </button>

      <span class="contact-copy-status" data-contact-copy-status aria-live="polite"></span>

      <a class="contact-email-button" href="mailto:wojseweryn@gmail.com">Email me</a>
    </div>

    <p class="contact-hero-note">
      Open to projects, advisory, and thoughtful technical conversations.
    </p>
  </section>

  <script is:inline>
    (() => {
      const button = document.querySelector("[data-contact-copy]");
      const status = document.querySelector("[data-contact-copy-status]");
      if (!(button instanceof HTMLButtonElement) || !(status instanceof HTMLElement)) return;

      let resetTimer;

      const showCopied = () => {
        status.textContent = "Copied";
        window.clearTimeout(resetTimer);
        resetTimer = window.setTimeout(() => {
          status.textContent = "";
        }, 1400);
      };

      button.addEventListener("click", async () => {
        const value = button.dataset.contactCopy ?? "";
        try {
          await navigator.clipboard.writeText(value);
          showCopied();
        } catch {
          const area = document.createElement("textarea");
          area.value = value;
          area.style.position = "fixed";
          area.style.opacity = "0";
          document.body.appendChild(area);
          area.focus();
          area.select();
          document.execCommand("copy");
          area.remove();
          showCopied();
        }
      });
    })();
  </script>
</BaseLayout>
