---
import { getReadingTime } from "../utils/readingTime";
import { formatShortDate } from "../utils/formatDate";

const { post, class: className = "", ...rest } = Astro.props;
const { title, description, pubDate, tags } = post.data;
const { minutes } = getReadingTime(post.body ?? "");

const primaryTag = tags?.[0] ?? "";
const tagSlugs = (tags ?? []).map((t: string) => t.toLowerCase());

const hasOptimizely = tagSlugs.includes("optimizely");
const hasAI = tagSlugs.includes("ai");
const isOptimizelyAI = hasOptimizely && hasAI;

const tagSlug = isOptimizelyAI ? "optimizely-ai" : primaryTag.toLowerCase();
const labelText = isOptimizelyAI ? "Optimizely AI" : primaryTag;
---
<article
  class={`card card-tilt card-tilt--${tagSlug} ${className}`.trim()}
  data-tilt-card
  data-card-click
  data-card-url={`/blog/${post.slug}`}
  tabindex="0"
  {...rest}
>
  <div class="card-surface flex gap-0">
    {primaryTag && (
      <div class={`post-label post-label--${tagSlug}`} aria-hidden="true">
        <span class="post-label-text">{labelText}</span>
      </div>
    )}
    <div class="flex flex-col gap-3 flex-1 min-w-0 p-6">
      <div class="text-xs text-ink-900/70 dark:text-ink-200/70">
        <time datetime={pubDate.toISOString()}>{formatShortDate(pubDate)}</time>
        <span aria-hidden="true">&middot;</span>
        <span>{minutes} min read</span>
      </div>
      <a href={`/blog/${post.slug}`} class="block">
        <h3 class="text-lg font-semibold">{title}</h3>
        <p class="mt-2 text-sm text-ink-900/80 dark:text-ink-200/80">{description}</p>
      </a>
      <div class="mt-1 flex flex-wrap gap-2">
        {tags.map((tag) => (
          <a
            class="tag-chip tag-chip-large"
            href={`/tag/${tag}`}
            aria-label={`Tag: ${tag}`}
            data-tag-link
          >
            #{tag}
          </a>
        ))}
      </div>
    </div>
  </div>
</article>
