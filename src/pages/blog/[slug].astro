---
import { Image, getImage } from "astro:assets";
import type { ImageMetadata } from "astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import GiscusComments from "../../components/GiscusComments.astro";
import { getCollection } from "astro:content";
import { getReadingTime } from "../../utils/readingTime";
import { formatShortDate } from "../../utils/formatDate";
import { getYearsExperience } from "../../utils/experience";
import aboutAuthorPhoto from "../../assets/about/wojciech-1.png";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { title, description, pubDate, tags, heroImage } = post.data;
const { Content, headings } = await post.render();
const { minutes } = getReadingTime(post.body ?? "");
const toc = headings.filter((heading) => heading.depth > 1 && heading.depth <= 3);
const tocListId = `toc-list-${post.slug}`;
const yearsExperience = getYearsExperience();
const contentImageModules = import.meta.glob<{ default: ImageMetadata }>(
  "../../assets/**/*.{avif,gif,jpeg,jpg,png,webp}",
  { eager: true }
);

const firstMarkdownImagePath = (() => {
  const match = post.body?.match(/!\[[^\]]*]\(([^)\s]+)(?:\s+"[^"]*")?\)/);
  const rawPath = match?.[1]?.trim().replace(/^<|>$/g, "");
  if (!rawPath) return undefined;

  const cleanPath = rawPath.split("#")[0].split("?")[0];
  const decodedPath = cleanPath.replace(/%20/g, " ");
  return contentImageModules[cleanPath]?.default
    ? cleanPath
    : contentImageModules[decodedPath]?.default
      ? decodedPath
      : undefined;
})();

const postOgImage = firstMarkdownImagePath ? contentImageModules[firstMarkdownImagePath]?.default : undefined;
const ogImage = heroImage ?? postOgImage;
const ogImageWebp = ogImage
  ? (await getImage({
      src: ogImage,
      width: Math.min(1200, ogImage.width),
      format: "webp",
      quality: 80
    })).src
  : undefined;

const otherPosts = (await getCollection("blog"))
  .filter((entry) => !entry.data.draft && entry.slug !== post.slug);

const relatedByTags = otherPosts
  .map((entry) => {
    const shared = entry.data.tags.filter((tag) => tags.includes(tag)).length;
    return { entry, shared };
  })
  .filter((item) => item.shared > 0)
  .sort((a, b) => {
    if (b.shared !== a.shared) return b.shared - a.shared;
    return b.entry.data.pubDate.valueOf() - a.entry.data.pubDate.valueOf();
  })
  .slice(0, 2)
  .map((item) => item.entry);

const fallbackPosts = otherPosts
  .filter((entry) => !relatedByTags.some((related) => related.slug === entry.slug))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, Math.max(2 - relatedByTags.length, 0));

const relatedPosts = [...relatedByTags, ...fallbackPosts].slice(0, 2);
---
<BaseLayout
  title={title}
  description={description}
  canonical={Astro.url}
  mainClass="post-layout"
  ogImage={ogImageWebp ?? ogImage}
  ogImageAlt={title}
>
  <div class="reading-progress" data-reading-progress></div>
  <button class="back-to-top" type="button" data-back-to-top aria-label="Back to top">
    <span class="back-to-top-icon" aria-hidden="true">↑</span>
  </button>
  <div class="article-shell">
    <article class="prose post-prose">
      <header class="post-hero">
        <h1>{title}</h1>
        <p class="post-meta text-sm text-ink-900/70 dark:text-ink-200/70">
      <time datetime={pubDate.toISOString()}>{formatShortDate(pubDate)}</time>
      <span aria-hidden="true"> · </span>
      <span>{minutes} min read</span>
        </p>
        <div class="post-tags mt-4 flex flex-wrap gap-2">
      {tags.map((tag) => (
        <a class="tag-chip tag-chip-large" href={`/tag/${tag}`}>
          #{tag}
        </a>
      ))}
        </div>
      </header>
      <div class="post-body-flow">
        {toc.length > 0 && (
      <nav
        class="toc not-prose"
        aria-label="Table of contents"
        data-toc
        data-expanded="false"
        data-toc-count={toc.length}
      >
        <div class="toc-title">Table of contents</div>
        <ul class="toc-list" id={tocListId}>
          {toc.map((heading) => (
            <li class={`toc-item depth-${heading.depth}`}>
              <a class="toc-link" href={`#${heading.slug}`}>{heading.text}</a>
            </li>
          ))}
        </ul>
        {toc.length > 3 && (
          <button
            class="toc-toggle"
            type="button"
            data-toc-toggle
            aria-controls={tocListId}
            aria-expanded="false"
            hidden
          >
            Show more...
          </button>
        )}
      </nav>
        )}
        <hr />
        <Content />
      </div>
    </article>
  </div>
  <section class="mt-12">
    <div class="section-divider" aria-hidden="true"></div>
    <div class="card-surface author-card mt-6 p-6">
      <div class="author-card-copy">
        <div class="author-card-header">
          <p class="author-card-kicker">About the author</p>
        </div>
        <div class="author-card-body">
          <h3 class="author-card-name">Wojciech Seweryn</h3>
          <p class="author-card-role home-eyebrow">Optimizely Expert • Lead Backend Developer • AI-Focused Builder</p>
          <p class="author-card-summary">
            Lead backend developer with {yearsExperience} years of commercial experience building enterprise
            platforms and tailored digital solutions. Writing about Optimizely, AI, architecture,
            experimentation, and practical implementation decisions.
          </p>
          <nav class="author-card-actions" aria-label="Author links">
            <a class="author-card-action" href="/about">About me</a>
            <a class="author-card-action" href="/contact">Get in touch</a>
            <a class="author-card-action" href="https://www.linkedin.com/in/wojciechseweryn/">
              Connect on LinkedIn
            </a>
          </nav>
        </div>
      </div>
      <Image
        class="author-card-photo"
        src={aboutAuthorPhoto}
        alt="Wojciech Seweryn"
        widths={[176, 240, 352]}
        sizes="(max-width: 640px) 148px, 176px"
        format="webp"
        quality={80}
        loading="lazy"
        decoding="async"
      />
    </div>
  </section>
  {relatedPosts.length >= 2 && (
    <section class="mt-12">
      <div class="section-divider" aria-hidden="true"></div>
      <h2 class="page-title text-2xl">Related posts</h2>
      <div class:list={{
        "mt-6 grid gap-6": true,
        "md:grid-cols-2": relatedPosts.length > 1
      }}>
        {relatedPosts.map((related) => (
          <PostCard post={related} class="card-compact" />
        ))}
      </div>
    </section>
  )}
  <GiscusComments />
</BaseLayout>
<script>
  import { initPostPageEnhancements } from "../../utils/postPage";

  initPostPageEnhancements();
</script>
