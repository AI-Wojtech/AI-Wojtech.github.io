---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  Boxes,
  ShoppingCart,
  Cable,
  Search,
  LifeBuoy,
  Blocks,
  Sparkles,
} from "lucide-astro";

const serviceAreas = [
  {
    icon: Boxes,
    title: "Optimizely platform development",
    wide: true,
    body: "Development and support across the Optimizely ecosystem, including:",
    items: [
      "Optimizely CMS",
      "Optimizely Customized Commerce",
      "Optimizely Data Platform",
      "Optimizely Product Recommendations",
      "Optimizely Web Experimentation",
      "Optimizely Feature Experimentation",
    ],
  },
  {
    icon: Sparkles,
    title: "AI-assisted development workflows",
    body: "Using AI tools in a practical way to improve development workflows, documentation, code review, knowledge sharing and everyday engineering productivity.",
  },
  {
    icon: ShoppingCart,
    title: "E-commerce development",
    body: "Support for product catalogs, basket and checkout flows, pricing logic, promotions, customer journeys and business-specific commerce requirements.",
  },
  {
    icon: Cable,
    title: "Integrations",
    body: "Implementation and troubleshooting of integrations with ERP, PIM, CRM, analytics, experimentation platforms, recommendation engines and other external systems.",
  },
  {
    icon: Search,
    title: "Technical audits and troubleshooting",
    body: "Investigation of production issues, performance problems, platform risks, broken integrations and difficult bugs that require deeper technical analysis.",
  },
  {
    icon: LifeBuoy,
    title: "Project takeover and maintenance support",
    body: "Helping teams understand, stabilize and continue development of existing platforms, especially when documentation is limited, the codebase is complex, or the original development team is no longer available.",
  },
  {
    icon: Blocks,
    title: "Architecture and implementation consulting",
    body: "Practical technical support for implementation decisions, C# and .NET refactoring, platform upgrades and making the system easier to maintain over time.",
  },
];
---
<BaseLayout
  title="Work with me"
  description="Independent B2B software development and consulting for Optimizely, .NET and e-commerce platforms."
  mainClass="wwm-layout"
>
  <section class="wwm-hero" data-reveal>
    <p class="wwm-eyebrow">B2B software development &amp; consulting</p>
    <h1 class="wwm-title">Work with me</h1>
    <p class="wwm-subtitle">
      Independent software development for Optimizely, .NET and e-commerce platforms
    </p>
  </section>

  <div class="card-surface wwm-intro-card" data-reveal>
    <div class="wwm-intro">
      <p>
        I help companies build, maintain and improve e-commerce platforms based on Optimizely, .NET and custom
        backend systems.
      </p>
      <p>
        Most of my work is around projects where things are not perfectly simple: custom business logic,
        integrations, legacy code, checkout flows, product data, tracking, experimentation, recommendations, or
        platforms that have grown over time and need someone who can understand both the code and the business
        process behind it.
      </p>
      <p>
        My main focus is Optimizely, .NET and commerce platforms, but I also work with the systems around them,
        such as ERP, PIM, analytics, experimentation tools, recommendation engines and operational support.
      </p>
    </div>
  </div>

  <section class="wwm-section" aria-labelledby="wwm-services-title">
    <h2 id="wwm-services-title" class="wwm-section-title" data-reveal>Service areas</h2>
    <div class="wwm-grid">
      {serviceAreas.map(({ icon: Icon, title, body, items, wide }, index) => (
        <article
          class:list={["card-surface", "wwm-card", wide && "wwm-card--wide"]}
          data-reveal
          style={`--reveal-delay:${index * 70}ms`}
        >
          <span class="wwm-card-icon" aria-hidden="true">
            <Icon size={22} stroke-width={1.7} />
          </span>
          <h3 class="wwm-card-title">{title}</h3>
          <p class="wwm-card-body">{body}</p>
          {items && (
            <ul class="wwm-card-list">
              {items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          )}
        </article>
      ))}
    </div>
  </section>

  <section class="wwm-section" aria-labelledby="wwm-cooperation-title">
    <h2 id="wwm-cooperation-title" class="wwm-section-title" data-reveal>How we can work together</h2>
    <div class="card-surface wwm-panel" data-reveal>
      <p>
        I work with companies on a B2B basis as an independent backend developer and technical consultant.
      </p>
      <p>
        Depending on the project, cooperation can be based on a defined scope, technical consulting, ongoing
        support, troubleshooting, project takeover or a longer-term B2B engagement.
      </p>
      <p>
        I usually work best with teams that need someone who can do more than just pick up isolated development
        tasks. Someone who can understand the platform, ask the right technical questions, identify risks early
        and help move the project forward.
      </p>
    </div>
  </section>

  <section class="wwm-section" aria-labelledby="wwm-contact-title">
    <div class="wwm-contact-grid">
      <div class="card-surface wwm-cta" data-reveal>
        <h2 id="wwm-contact-title" class="wwm-cta-title">Get in touch</h2>
        <p class="wwm-cta-copy">
          If you are working with Optimizely, .NET or a complex e-commerce platform and need technical support,
          feel free to reach out.
        </p>
        <a class="contact-email-button" href="mailto:wojtechseweryn@gmail.com">wojtechseweryn@gmail.com</a>
      </div>

      <aside class="card-surface wwm-company" data-reveal aria-labelledby="wwm-company-title">
        <h2 id="wwm-company-title" class="wwm-company-title">Company details</h2>
        <dl class="wwm-company-list">
          <div class="wwm-company-row">
            <dt>Business name</dt>
            <dd>Wojciech Seweryn</dd>
          </div>
          <div class="wwm-company-row">
            <dt>NIP</dt>
            <dd>6812095100</dd>
          </div>
          <div class="wwm-company-row">
            <dt>REGON</dt>
            <dd>523074440</dd>
          </div>
          <div class="wwm-company-row">
            <dt>Country</dt>
            <dd>Poland</dd>
          </div>
        </dl>
      </aside>
    </div>
  </section>

  <script is:inline>
    (() => {
      const targets = Array.from(document.querySelectorAll("[data-reveal]"));
      if (targets.length === 0) return;

      const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (prefersReduced || !("IntersectionObserver" in window)) {
        targets.forEach((el) => el.classList.add("is-visible"));
        return;
      }

      const observer = new IntersectionObserver(
        (entries, obs) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              obs.unobserve(entry.target);
            }
          });
        },
        { rootMargin: "0px 0px -10% 0px", threshold: 0.12 }
      );

      targets.forEach((el) => observer.observe(el));
    })();
  </script>
</BaseLayout>
