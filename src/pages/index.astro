---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import { BookOpenText, Github, Linkedin, Mail, Rss, UserRound } from "lucide-astro";
import siteLogo from "../assets/branding/ws-blog-logo.png";
import ThemeToggle from "../components/ThemeToggle.astro";
import RotatingWords from "../components/RotatingWords.astro";
import { ROTATING_EXPERTISE_TOPICS } from "../utils/rotatingTopics";

const emailAddress = "wojseweryn@gmail.com";

const actionCards = [
  {
    href: "/about",
    icon: UserRound,
    title: "About Me",
    body: "Background, experience, and the kind of platform challenges I help solve.",
  },
  {
    href: "/contact",
    icon: Mail,
    title: "Contact",
    body: "Reach out if you want to improve an existing platform or build something new.",
  },
  {
    href: "/blog",
    icon: BookOpenText,
    title: "My Blog",
    body: "Hands-on articles about Optimizely, platform architecture, AI, and modern engineering.",
  },
];

const socialLinks = [
  { href: "https://www.linkedin.com/in/wojciechseweryn/", label: "LinkedIn", icon: Linkedin },
  { href: "https://github.com/AI-Wojtech", label: "GitHub", icon: Github },
  { copyEmail: true, label: "Copy email", icon: Mail },
  { href: "/rss.xml", label: "RSS", icon: Rss },
];

---
<BaseLayout
  title="Home"
  description="Optimizely expert and AI-focused software engineer writing about implementation, architecture, and practical engineering work."
  mainClass="home-layout"
  showHeader={false}
>
  <section class="home-landing-shell">
    <div class="home-landing-panel">
      <div class="home-landing-topbar">
        <a href="/" class="home-brand">
          <Image
            class="home-brand-logo"
            src={siteLogo}
            alt="WS Blog logo"
            widths={[120, 160, 200]}
            sizes="(max-width: 640px) 120px, 160px"
            format="webp"
            quality={90}
            loading="eager"
            decoding="async"
          />
        </a>

        <div class="home-landing-nav-group">
          <nav class="home-landing-nav" aria-label="Homepage">
            <a class="home-top-link" href="/about">About Me</a>
            <a class="home-top-link" href="/contact">Contact</a>
            <a class="home-top-link" href="/blog">Blog</a>
          </nav>

          <div class="home-top-icons">
            <ThemeToggle />
            <a class="home-top-icon-link" href="https://github.com/AI-Wojtech" aria-label="GitHub">
              <Github size={18} />
            </a>
            <button
              type="button"
              class="home-top-icon-link home-copy-trigger"
              data-copy-email={emailAddress}
              data-copy-default-label="Copy email"
              data-copy-copied-label="Email copied"
              aria-label="Copy email"
              title="Copy email"
            >
              <Mail size={18} />
            </button>
          </div>
        </div>
      </div>

      <div class="home-landing-divider" aria-hidden="true"></div>

      <div class="home-landing-content">
        <div class="home-landing-main">
          <div class="home-copy-stack">
            <p class="home-eyebrow">Optimizely Expert • Software Engineer • AI-Focused Builder</p>
            <h1 class="home-title">Hello👋 I&apos;m Wojciech Seweryn</h1>
            <div class="home-landing-summary">
              <p class="home-summary-line home-summary-line--primary">
                <span class="home-summary-prefix">Turning data into decisions with expertise in</span>
                <RotatingWords
                  class="home-inline-rotator"
                  items={ROTATING_EXPERTISE_TOPICS}
                  typeSpeedMs={42}
                  deleteSpeedMs={22}
                  holdMs={1020}
                  nextWordDelayMs={120}
                />
              </p>
              <p class="home-summary-line home-summary-line--secondary">
                Engineering better digital platforms with Optimizely, AI, and experimentation.
                <br />
                Practical architecture, thoughtful implementation, and measurable outcomes.
              </p>
            </div>
          </div>

          <div class="home-action-grid" aria-label="Homepage navigation">
            {actionCards.map(({ href, icon: Icon, title, body }) => (
              <a class="home-action-card" href={href}>
                <span class="home-action-icon" aria-hidden="true">
                  <Icon size={30} stroke-width={1.65} />
                </span>
                <span class="home-action-title">{title}</span>
                <span class="home-action-body">{body}</span>
              </a>
            ))}
          </div>
        </div>

        <div class="home-landing-bottom">
          <p class="home-landing-note">
            Have a platform to improve, an idea to validate, or a technical direction to clarify? Let&apos;s talk.
          </p>

          <div class="home-social-row" aria-label="Social links">
            {socialLinks.map(({ href, label, icon: Icon, copyEmail }) =>
              copyEmail ? (
                <button
                  type="button"
                  class="home-social-link home-copy-trigger"
                  data-copy-email={emailAddress}
                  data-copy-default-label={label}
                  data-copy-copied-label="Email copied"
                  aria-label={label}
                  title={label}
                >
                  <Icon size={18} />
                </button>
              ) : (
                <a class="home-social-link" href={href} aria-label={label}>
                  <Icon size={18} />
                </a>
              )
            )}
          </div>
        </div>
      </div>
    </div>
  </section>
  <script is:inline>
    (() => {
      const buttons = Array.from(document.querySelectorAll("[data-copy-email]"));
      if (buttons.length === 0) return;

      const copyText = async (value) => {
        try {
          await navigator.clipboard.writeText(value);
        } catch {
          const area = document.createElement("textarea");
          area.value = value;
          area.style.position = "fixed";
          area.style.opacity = "0";
          document.body.appendChild(area);
          area.focus();
          area.select();
          document.execCommand("copy");
          area.remove();
        }
      };

      buttons.forEach((button) => {
        if (!(button instanceof HTMLButtonElement)) return;

        let resetTimer = 0;
        const defaultLabel = button.dataset.copyDefaultLabel ?? "Copy email";
        const copiedLabel = button.dataset.copyCopiedLabel ?? "Email copied";

        button.addEventListener("click", async () => {
          const value = button.dataset.copyEmail ?? "";
          if (!value) return;

          await copyText(value);
          button.classList.add("is-copied");
          button.setAttribute("aria-label", copiedLabel);
          button.setAttribute("title", copiedLabel);

          window.clearTimeout(resetTimer);
          resetTimer = window.setTimeout(() => {
            button.classList.remove("is-copied");
            button.setAttribute("aria-label", defaultLabel);
            button.setAttribute("title", defaultLabel);
          }, 1400);
        });
      });
    })();
  </script>
</BaseLayout>
